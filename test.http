### ==========================================
### 5. HATALI TESTLER (EDGE CASES - DEMO KISMI)
### ==========================================

# 5.1 - Uyumsuz Connector Type (400 Bad Request dönmeli)
# Senaryo: Vehicle 3 (Zoe - TYPE2), Charger 1'den (CCS Tipi Şarj) rezervasyon yapmaya çalışıyor.
POST {{baseUrl}}/reservations
Content-Type: application/json

{
  "vehicleId": 3,
  "chargerId": 1,
  "startTime": "2026-06-15T10:00:00",
  "endTime": "2026-06-15T11:00:00"
}

###
# 5.2 - Geçmiş Tarih/Saat (400 Bad Request dönmeli)
# Senaryo: Başlangıç tarihi bugünden (2026 Nisan'dan) önceki bir zamana ayarlanmış.
POST {{baseUrl}}/reservations
Content-Type: application/json

{
  "vehicleId": 1,
  "chargerId": 1,
  "startTime": "2025-01-01T10:00:00",
  "endTime": "2025-01-01T11:00:00"
}

###
# 5.3 - 2 Saatten Uzun Rezervasyon (400 Bad Request dönmeli)
# Senaryo: 10:00'dan 13:00'a kadar toplam 3 saatlik rezervasyon talebi.
POST {{baseUrl}}/reservations
Content-Type: application/json

{
  "vehicleId": 1,
  "chargerId": 1,
  "startTime": "2026-06-20T10:00:00",
  "endTime": "2026-06-20T13:00:00"
  "startTime": "2026-04-28T14:00:00",
  "endTime": "2026-04-28T16:00:00"
}

###
# 5.4 - Dolu Charger'a Rezervasyon (Conflict veya Bad Request dönmeli)
# Önce başarılı, meşru bir rezervasyon oluşturuyoruz. (Araç 1, Charger 2'yi alıyor)
POST {{baseUrl}}/reservations
Content-Type: application/json

{
  "vehicleId": 1,
  "chargerId": 2,
  "startTime": "2026-06-25T14:00:00",
  "endTime": "2026-06-25T15:00:00"
  "chargerId": 1,
  "startTime": "2026-04-28T12:37:00",
  "endTime": "2026-04-28T12:39:00"
}

###
# Şimdi aynı saat dilimine, başka bir araçla (Araç 2) AYNI şarj ünitesine (Charger 2) girmeye çalışıyoruz.
POST {{baseUrl}}/reservations
Content-Type: application/json

{
  "vehicleId": 2,
  "chargerId": 2,
  "startTime": "2026-06-25T14:30:00",
  "endTime": "2026-06-25T15:30:00"
}







### Ekstra: projedeki bazı otomasyon gibi örünen özel kod kısımları (görev tanımı dışında görünen) aşağıda yazdım silmek yerine, gerek duyulursa silinebilir

> {%
client.global.set("manualReservationId", response.body.id);
%}

###
POST {{baseUrl}}/sessions/start?reservationId={{manualReservationId}}&startBatteryLevel=20

> {%
    client.global.set("manualSessionId", response.body.id);
%}

###
POST {{baseUrl}}/sessions/{{manualSessionId}}/end?endBatteryLevel=80

###
GET {{baseUrl}}/sessions/{{manualSessionId}}

###
GET {{baseUrl}}/reservations/{{manualReservationId}}

###
GET {{baseUrl}}/chargers/1

###
# Scheduler auto-complete scenario
POST {{baseUrl}}/reservations
Content-Type: application/json

{
  "vehicleId": 3,
  "chargerId": 1,
  "startTime": "2026-04-25T12:01:30",
  "endTime": "2026-04-25T12:03:30"
}

> {%
    client.global.set("autoReservationId", response.body.id);
%}

###
POST {{baseUrl}}/sessions/start?reservationId={{autoReservationId}}&startBatteryLevel=20

> {%
    client.global.set("autoSessionId", response.body.id);
%}

###
# Wait at least 60 seconds after reservation endTime, then run:
GET {{baseUrl}}/sessions/{{autoSessionId}}

###
GET {{baseUrl}}/reservations/{{autoReservationId}}

###
GET {{baseUrl}}/chargers/1

