  "projectType": "saas",
  "projectName": "ChargeGo",
  "projectDescription": "A web application for discovering EV charging stations, managing reservations, and tracking charging sessions.",
  "theme": "almond",
  "primaryColor": "#2ECC71",
  "lightColor": "#A9DFBF",
  "darkColor": "#1A8A4A",
